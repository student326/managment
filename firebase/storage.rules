rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Excel files are private - only authenticated admins can access
    match /excel/{allPaths=**} {
      allow read, write: if request.auth != null;
    }
    
    // Default deny all other access
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}

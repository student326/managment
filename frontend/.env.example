# Firebase Configuration (Required)
# These are public-facing Firebase client config keys
# They are safe to expose in frontend code as they are designed for client use
# However, ensure Firebase Security Rules are properly configured
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=1:000000000000:web:your_app_id
